{
  "name": "infraclaude",
  "version": "1.0.0",
  "description": "MCP Server for Infrastructure Management — Kubernetes, Docker, Terraform, Prometheus, and Security tools for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "infraclaude": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "kubernetes",
    "docker",
    "terraform",
    "prometheus",
    "infrastructure",
    "devops",
    "sre",
    "claude-code"
  ],
  "author": "Batu Sonmez",
  "license": "MIT",
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dockerode": "^4.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
